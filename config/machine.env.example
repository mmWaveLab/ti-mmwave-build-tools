# Copy this file to config/machine.env on each machine.
# Do not commit config/machine.env if it contains local-only paths.

# Docker image name.
IMAGE=ti-mmwave-build-tools:linux-smoke

# Native path to the TI SDK/tool installation on the host.
# On labpc this is /opt/ti.
HOST_TI_ROOT=/opt/ti

# Path exposed inside the container. Keep this stable because TI configuro and
# generated make fragments embed absolute paths.
CONTAINER_TI_ROOT=/opt/ti

# Native builds use TI_ROOT directly.
TI_ROOT=/opt/ti

# Generated outputs. These can be moved to a scratch disk on CI runners.
BUILD_ROOT=
ARTIFACT_DIR=
REPORT_DIR=
