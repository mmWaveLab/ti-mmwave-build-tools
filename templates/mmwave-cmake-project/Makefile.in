IMAGE ?= ti-mmwave-build-tools:linux-smoke
TI_ROOT ?= /home/kj/ti
HOST_TI_ROOT ?= $(TI_ROOT)
BUILD_DIR ?= build

.PHONY: configure build clean

configure:
	cmake -S . -B $(BUILD_DIR) -G Ninja -DTI_ROOT=$(TI_ROOT)

build: configure
	cmake --build $(BUILD_DIR) --target firmware

clean:
	rm -rf $(BUILD_DIR)
