IMAGE ?= @SDK_IMAGE@
BUILD_DIR ?= build

.PHONY: pull configure build shell clean

pull:
	docker pull $(IMAGE)

configure:
	docker run --rm \
	  --user "$$(id -u):$$(id -g)" \
	  -e HOME=/tmp \
	  -v "$$(pwd)":/work/app \
	  -w /work/app \
	  $(IMAGE) \
	  cmake -S . -B $(BUILD_DIR) -G Ninja -DTI_ROOT=/home/kj/ti

build: configure
	docker run --rm \
	  --user "$$(id -u):$$(id -g)" \
	  -e HOME=/tmp \
	  -v "$$(pwd)":/work/app \
	  -w /work/app \
	  $(IMAGE) \
	  cmake --build $(BUILD_DIR) --target firmware

shell:
	docker run --rm -it \
	  --user "$$(id -u):$$(id -g)" \
	  -e HOME=/tmp \
	  -v "$$(pwd)":/work/app \
	  -w /work/app \
	  $(IMAGE) \
	  bash

clean:
	rm -rf $(BUILD_DIR)
