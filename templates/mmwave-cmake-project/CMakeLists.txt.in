cmake_minimum_required(VERSION 3.20)
project(@PROJECT_NAME@ NONE)

set(TI_MMWAVE_TOOLS_ROOT "$ENV{TI_MMWAVE_TOOLS_ROOT}" CACHE PATH "ti-mmwave-build-tools path inside the SDK Docker image")
if(NOT TI_MMWAVE_TOOLS_ROOT)
  set(TI_MMWAVE_TOOLS_ROOT "/opt/ti-mmwave-build-tools" CACHE PATH "ti-mmwave-build-tools path inside the SDK Docker image" FORCE)
endif()
list(APPEND CMAKE_MODULE_PATH "${TI_MMWAVE_TOOLS_ROOT}/cmake")
include(TiMmwaveSdkPaths)

set(MMWAVE_SDK_DEVICE "@SDK_DEVICE@" CACHE STRING "mmWave SDK device")
set(MMWAVE_SDK_DEVICE_TYPE "@SDK_DEVICE_TYPE@" CACHE STRING "mmWave SDK device type")
set(MMWAVE_DEMO_PROFILE "@PROFILE@" CACHE STRING "mmWave demo profile used to create this project")
set(MMWAVE_BUILD_TARGET "@BUILD_TARGET@" CACHE STRING "TI make target used to build this profile")
set(MMWAVE_CLEAN_TARGET "@CLEAN_TARGET@" CACHE STRING "TI make target used to clean this profile")
set(MMWAVE_EXTRA_MAKE_ARGS "@MAKE_EXTRA_ARGS@" CACHE STRING "Extra TI make arguments for this profile")
set(APP_SOURCE_DIR "${CMAKE_CURRENT_LIST_DIR}/app")
set(APP_BUILD_DIR "${CMAKE_BINARY_DIR}/app")
set(OUTPUT_BIN "${APP_BUILD_DIR}/@OUTPUT_BIN@")

foreach(required_path
    "${APP_SOURCE_DIR}/makefile"
    "${MMWAVE_SDK_PACKAGES}/scripts/unix/generateMetaImage.sh")
  if(NOT EXISTS "${required_path}")
    message(FATAL_ERROR "Required path not found: ${required_path}")
  endif()
endforeach()

add_custom_command(
  OUTPUT "${OUTPUT_BIN}"
  COMMAND "${CMAKE_COMMAND}" -E rm -rf "${APP_BUILD_DIR}"
  COMMAND "${CMAKE_COMMAND}" -E copy_directory "${APP_SOURCE_DIR}" "${APP_BUILD_DIR}"
  COMMAND "${CMAKE_COMMAND}" -E env
    "CCS_MAKEFILE_BASED_BUILD=1"
    "MMWAVE_SDK_DEVICE=${MMWAVE_SDK_DEVICE}"
    "MMWAVE_SDK_DEVICE_TYPE=${MMWAVE_SDK_DEVICE_TYPE}"
    "MMWAVE_SDK_TOOLS_INSTALL_PATH=${TI_ROOT}"
    "MMWAVE_SDK_INSTALL_PATH=${MMWAVE_SDK_PACKAGES}"
    "${CMAKE_COMMAND}" -E chdir "${APP_BUILD_DIR}"
    make -f makefile "${MMWAVE_CLEAN_TARGET}" ${MMWAVE_EXTRA_MAKE_ARGS}
  COMMAND "${CMAKE_COMMAND}" -E env
    "CCS_MAKEFILE_BASED_BUILD=1"
    "MMWAVE_SDK_DEVICE=${MMWAVE_SDK_DEVICE}"
    "MMWAVE_SDK_DEVICE_TYPE=${MMWAVE_SDK_DEVICE_TYPE}"
    "MMWAVE_SDK_TOOLS_INSTALL_PATH=${TI_ROOT}"
    "MMWAVE_SDK_INSTALL_PATH=${MMWAVE_SDK_PACKAGES}"
    "${CMAKE_COMMAND}" -E chdir "${APP_BUILD_DIR}"
    make -f makefile "${MMWAVE_BUILD_TARGET}" ${MMWAVE_EXTRA_MAKE_ARGS}
  WORKING_DIRECTORY "${CMAKE_BINARY_DIR}"
  VERBATIM
  COMMENT "Building forked @SDK_DEVICE_TYPE@ firmware"
)

add_custom_target(firmware ALL DEPENDS "${OUTPUT_BIN}")

install(FILES "${OUTPUT_BIN}" DESTINATION .)
